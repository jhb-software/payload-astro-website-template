MONGODB_URI="mongodb://localhost:27017/payload-astro-website-template" # The Connection string of your DB where the string after "/"" represents the name. For the deployed envs, you can copy this from MongoDB Atlas.

PAYLOAD_SECRET="" # TODO: generate a random secret. See https://payloadsecret.io/ for more info
NEXT_PUBLIC_FRONTEND_URL="http://localhost:4321" # The URL of your frontend. This should be the same as WEBSITE_URL in the web .env file.

S3_BUCKET="" # TODO: add the S3 bucket name (e.g. from Hetzner Object Storage, AWS S3, R2, ...)
S3_REGION="" # TODO: add the S3 region (e.g. "nbg1" for Hetzner Nuremberg, "eu-central-1" for AWS Frankfurt)
S3_ENDPOINT="" # TODO: add the S3-compatible endpoint URL (e.g. "https://nbg1.your-objectstorage.com" for Hetzner). Leave empty for AWS S3.
S3_ACCESS_KEY_ID="" # TODO: add the S3 access key id
S3_SECRET_ACCESS_KEY="" # TODO: add the S3 secret access key

RESEND_API_KEY="" # TODO: add the resend api key. You can copy this from the Resend dashboard.

NEXT_PUBLIC_WEBSITE_VERCEL_DEPLOY_URL="" # TODO: add website deployment hook URL. You can generate this in the Vercel Project dashboard.