{
  "name": "cms",
  "version": "1.0.0",
  "description": "JHB Payload Astro Website Template - CMS",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "format": "prettier --write src",
    "check": "cross-env NODE_OPTIONS=--no-deprecation tsc --noEmit",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@jhb.software/payload-alt-text-plugin": "^0.4.4",
    "@jhb.software/payload-pages-plugin": "^0.7.0",
    "@jhb.software/payload-vercel-deployments": "^0.2.1",
    "@payloadcms/db-mongodb": "3.84.1",
    "@payloadcms/email-resend": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-cloud-storage": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-s3": "3.84.1",
    "@payloadcms/translations": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@vercel/functions": "^3.4.3",
    "cross-env": "^10.1.0",
    "graphql": "^16.11.0",
    "next": "16.2.6",
    "payload": "3.84.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.0",
    "eslint": "^9.37.0",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
