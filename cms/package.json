{
  "name": "cms",
  "version": "1.0.0",
  "description": "JHB Payload Astro Website Template - CMS",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "format": "prettier --write src",
    "check": "cross-env NODE_OPTIONS=--no-deprecation tsc --noEmit",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@jhb.software/payload-alt-text-plugin": "^0.9.1",
    "@jhb.software/payload-pages-plugin": "^0.8.0",
    "@jhb.software/payload-vercel-deployments": "^0.3.1",
    "@payloadcms/db-mongodb": "3.86.0",
    "@payloadcms/email-resend": "3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/plugin-cloud-storage": "3.86.0",
    "@payloadcms/plugin-seo": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/storage-s3": "3.86.0",
    "@payloadcms/translations": "3.86.0",
    "@payloadcms/ui": "3.86.0",
    "@vercel/functions": "^3.7.5",
    "cross-env": "^10.1.0",
    "graphql": "^17.0.2",
    "next": "16.2.10",
    "payload": "3.86.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
